# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# 正式部署走 GitHub Actions cron drain(npm run drain);npm run dev = 本機 long polling(開發用)。
# 本機 Docker/WSL2 跑常駐會撞 googleapis Premature close —— Docker/webhook 線已於 2026-07-03 解散。
# 儲存:sheets(寫 Google,需憑證) 或 memory(乾跑,不寫真表,只需 token)
STORAGE=sheets

# ── Google Sheets ─────────────────────────────────────────────────────────
# 三選一(優先序:JSON 字串 > base64 > 檔案路徑):
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

GOOGLE_SHEET_ID=<SHEET_ID>
# voc 的「參考池」分頁名(同一張表):bot 直寫,不再經暫存區。挑片在 Sheet 勾「挑」(/pick 已退役 2026-06-23)。
POOL_SHEET_NAME=參考池

# ── 行為 ──────────────────────────────────────────────────────────────────
# 來源白名單:只處理這些 chat/user id 的訊息(公開後防陌生人灌池),逗號分隔純數字。
# 私訊填你的 user id;群組收集填群 id(負數,例:-48214680)。
# ★ STORAGE=sheets 時必填,沒填啟動就 fail-fast(寧可不跑也不大開)。memory 乾跑可留空。
ALLOWED_CHAT_IDS=
# 錯誤回報 chat（collect/stats 失敗時 bot 主動通知這個 chat;正式部署從 GitHub secret 注入)
ERROR_CHAT_ID=
# 短網址是否自動跟隨 redirect 展開(會發網路請求;預設關)
EXPAND_SHORT_URLS=false

# ── 其他 ──────────────────────────────────────────────────────────────────
# 注:加入日期一律 Asia/Taipei ISO YYYY-MM-DD(寫死於 utils/date.ts),無需設 TZ。
# 去重:參考池是 voc 永久池,bot 只 append 不刪列,去重靠連結 key 全表比對(無時間窗)。
LOG_LEVEL=info
