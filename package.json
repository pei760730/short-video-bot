{
  "name": "short-video-bot",
  "version": "0.1.0",
  "description": "Telegram 短影音收集 bot — 取代 n8n 版本(解析→清理→判斷平台→抽 video ID→去重→寫 Google Sheet)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "drain": "tsx src/drain.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@pei760730/collector-core": "github:pei760730/collector-core#v0.3.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
