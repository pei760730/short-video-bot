# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# 部署模式:polling(開發 / 雲端常駐用) 或 webhook
# 注意:正式部署走 GitHub Actions cron drain(npm run drain),不靠這個常駐模式。
# 本機 Docker/WSL2 跑 polling 會撞 googleapis Premature close,要常駐請上雲端 VM。
BOT_MODE=polling
# 儲存:sheets(寫 Google,需憑證) 或 memory(乾跑,不寫真表,只需 token)
STORAGE=sheets
# webhook 模式才需要(對外可達的網址,Telegram 會打這個):
WEBHOOK_DOMAIN=
WEBHOOK_PATH=/telegraf
PORT=8080

# ── Google Sheets ─────────────────────────────────────────────────────────
# 三選一(優先序:JSON 字串 > base64 > 檔案路徑):
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

GOOGLE_SHEET_ID=1Od1MOJWILSYmNs_kfRY05VInLJx4MO3b5riDtCX3Keo
STAGING_SHEET_NAME=暫存區

# ── 行為 ──────────────────────────────────────────────────────────────────
# 通知用 chat（管理 / 錯誤回報）
ADMIN_CHAT_ID=-48214680
ERROR_CHAT_ID=-48214680
# 幾天內的同 VIDEO_ID 才算重複
DEDUPE_PERIOD_DAYS=180
# 短網址是否自動跟隨 redirect 展開(會發網路請求;預設關)
EXPAND_SHORT_URLS=false

# ── 其他 ──────────────────────────────────────────────────────────────────
TZ=Asia/Taipei
LOG_LEVEL=info
